{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "npx nuxi typecheck",
    "lint": "eslint . --ext .js,.ts,.vue,.mjs",
    "lint:fix": "eslint . --ext .js,.ts,.vue,.mjs --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:nuxt": "vitest --project nuxt",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.12.1",
    "nuxt": "^4.2.2",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/test-utils": "^3.23.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^25.0.8",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.1"
  }
}